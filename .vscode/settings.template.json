{
    "cmake.useVsDeveloperEnvironment": "always",
    "files.associations": {
        "*.toml": "toml",
        "*.h": "c",
        "*.c": "c",
        "*.hpp": "cpp",
        "*.cpp": "cpp"
    },
    "files.exclude": {
        ".cache/": true,
        ".vs": true,
        "**/DX11RHI/**": true,
        "**/*.hlsl": true,
        "**/MetalRHI/**": true,
        "**/*.metal": true
    },
    "search.exclude": {
        ".cache/": true,
        ".vs": true,
        "**/DX11RHI/**": true,
        "**/*.hlsl": true,
        "**/MetalRHI/**": true,
        "**/*.metal": true
    },
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.path": "/path/to/clangd",
    "github.copilot.enable": {
        "*": false
    },
    "cmake.modifyLists.addNewSourceFiles": "no"
}