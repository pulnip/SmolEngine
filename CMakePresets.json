{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "build"
        },
        {
            "name": "Windows-llvm",
            "hidden": true,
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "generator": "Ninja Multi-Config",
            "toolchainFile": "${sourceDir}/cmake/toolchains/windows-llvm.cmake"
        },
        {
            "name": "Windows-llvm-x64",
            "displayName": "llvm-x64",
            "inherits": "Windows-llvm",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            }
        },
        {
            "name": "Windows-llvm-x86",
            "displayName": "llvm-x86",
            "inherits": "Windows-llvm",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            }
        },
        {
            "name": "macOS-brew-llvm",
            "displayName": "brew-llvm",
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "generator": "Ninja Multi-Config",
            "toolchainFile": "${sourceDir}/cmake/toolchains/brew-llvm.cmake"
        }
    ],
    "buildPresets": [
        {
            "name": "Windows-llvm-x64-Debug",
            "displayName": "x64-Debug",
            "configurePreset": "Windows-llvm-x64",
            "configuration": "Debug"
        },
        {
            "name": "Windows-llvm-x64-RelWithDebInfo",
            "displayName": "x64-RelWithDebInfo",
            "configurePreset": "Windows-llvm-x64",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "Windows-llvm-x64-Release",
            "displayName": "x64-Release",
            "configurePreset": "Windows-llvm-x64",
            "configuration": "Release"
        },
        {
            "name": "Windows-llvm-x86-Debug",
            "displayName": "x86-Debug",
            "configurePreset": "Windows-llvm-x86",
            "configuration": "Debug"
        },
        {
            "name": "Windows-llvm-x86-RelWithDebInfo",
            "displayName": "x86-RelWithDebInfo",
            "configurePreset": "Windows-llvm-x86",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "Windows-llvm-x86-Release",
            "displayName": "x86-Release",
            "configurePreset": "Windows-llvm-x86",
            "configuration": "Release"
        },
        {
            "name": "macOS-brew-llvm-Debug",
            "displayName": "Debug",
            "configurePreset": "macOS-brew-llvm",
            "configuration": "Debug"
        },
        {
            "name": "macOS-brew-llvm-RelWithDebInfo",
            "displayName": "RelWithDebInfo",
            "configurePreset": "macOS-brew-llvm",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "macOS-brew-llvm-Release",
            "displayName": "Release",
            "configurePreset": "macOS-brew-llvm",
            "configuration": "Release"
        }
    ]
}